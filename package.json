{
  "name": "avitan-dojo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:init": "prisma migrate dev --name initial_schema",
    "vercel-build": "prisma migrate deploy && next build",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:backfill-student-status": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/backfill-student-status.ts",
    "db:seed-fake-load": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/seed-fake-load-data.ts",
    "db:seed-fake-payments": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/seed-fake-payments-only.ts"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10",
    "typescript": "^5"
  }
}
